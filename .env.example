# ElementIQ Frontend — Environment Configuration
# Copy to .env and fill values: cp .env.example .env

# ── Server Ports ──────────────────────────────────────────────
PORT=3000
BACKEND_URL=http://localhost:8001
# Leave VITE_BACKEND_URL unset for local dev — browser uses /api/v1 via port 3000 proxy
# VITE_BACKEND_URL=

# ── Supabase Auth (public keys only) ─────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
